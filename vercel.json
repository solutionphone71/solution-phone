{
  "functions": {
    "api/render/gpt-image.js":      { "maxDuration": 60 },
    "api/visual/process-queue.js":  { "maxDuration": 60 },
    "api/visual/quality-check.js":  { "maxDuration": 60 },
    "api/agents/zahira.js":         { "maxDuration": 60 },
    "api/agents/trigger.js":        { "maxDuration": 60 },
    "api/autopilot/execute.js":     { "maxDuration": 60 }
  },
  "rewrites": [
    { "source": "/proxy-kiwiz/:path*",        "destination": "/api/proxy-kiwiz" },
    { "source": "/proxy-ecosystem/:path*",    "destination": "/api/proxy-ecosystem" },
    { "source": "/proxy-ecologic/:path*",     "destination": "/api/proxy-ecologic" },
    { "source": "/api/google-oauth-init",     "destination": "/api/google-reviews.js" },
    { "source": "/api/google-oauth-callback", "destination": "/api/google-reviews.js" },
    { "source": "/api/google-reviews",        "destination": "/api/google-reviews.js" },
    { "source": "/api/cron-reviews",          "destination": "/api/google-reviews.js" },
    { "source": "/api/google-reviews-config", "destination": "/api/google-reviews.js" }
  ],
  "crons": [
    { "path": "/api/cron-reviews",                "schedule": "0 9 * * *" },
    { "path": "/api/agents/zahira?type=morning",  "schedule": "0 8 * * *" },
    { "path": "/api/agents/zahira?type=evening",  "schedule": "0 19 * * *" },
    { "path": "/api/agents/zahira?type=weekly",   "schedule": "0 18 * * 0" },
    { "path": "/api/brain/morning-run",           "schedule": "5 8 * * *" },
    { "path": "/api/backup",                      "schedule": "0 2 * * *" },
    { "path": "/api/agents/insights",             "schedule": "0 3 * * *" },
    { "path": "/api/agents/briefing",             "schedule": "45 7 * * *" },
    { "path": "/api/visual/process-queue",        "schedule": "*/15 * * * *" }
  ],
  "headers": [
    {
      "source": "/css/(.*)",
      "headers": [
        { "key": "Cache-Control", "value": "no-cache, no-store, must-revalidate" },
        { "key": "Pragma",        "value": "no-cache" }
      ]
    },
    {
      "source": "/client.html",
      "headers": [
        { "key": "Cache-Control", "value": "no-cache, no-store, must-revalidate" },
        { "key": "Pragma",        "value": "no-cache" },
        { "key": "Expires",       "value": "0" }
      ]
    },
    {
      "source": "/",
      "headers": [
        { "key": "Cache-Control", "value": "no-cache, no-store, must-revalidate" },
        { "key": "Pragma",        "value": "no-cache" },
        { "key": "Expires",       "value": "0" }
      ]
    },
    {
      "source": "/index.html",
      "headers": [
        { "key": "Cache-Control", "value": "no-cache, no-store, must-revalidate" },
        { "key": "Pragma",        "value": "no-cache" },
        { "key": "Expires",       "value": "0" }
      ]
    },
    {
      "source": "/sw.js",
      "headers": [
        { "key": "Cache-Control", "value": "no-cache, no-store, must-revalidate" }
      ]
    }
  ]
}
