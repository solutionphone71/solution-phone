{
    "rewrites": [
        {
            "source": "/proxy-kiwiz/:path*",
            "destination": "https://api.kiwiz.io/:path*"
        },
        {
            "source": "/proxy-ecosystem/:path*",
            "destination": "https://api-reparateurs.ecosystem.eco/:path*"
        },
        {
            "source": "/proxy-ecologic/:path*",
            "destination": "https://apiecologic.e-reparateur.eco/api/v1/ecosupport/:path*"
        }
    ]
}